# LLM - get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=agentic_db

# REST API base URL (no trailing slash)
REST_BASE_URL=https://your-api-base-url.com

# Filesystem — directory the filesystem MCP server is allowed to access
FILES_DIR=/absolute/path/to/your/files/directory

# Excel output file (must exist before running)
EXCEL_FILE_PATH=/absolute/path/to/your/files/directory/newdata.xlsx

# Excel MCP paging limit (cells per page)
EXCEL_MCP_PAGING_CELLS_LIMIT=4000
